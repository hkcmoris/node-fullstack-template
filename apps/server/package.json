{
    "name": "@replace-me/server",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc -p tsconfig.build.json",
        "start": "node dist/index.js",
        "test": "node --import tsx --test \"test/**/*.test.ts\"",
        "typecheck": "tsc --noEmit -p tsconfig.json"
    },
    "dependencies": {
        "@replace-me/shared": "0.1.0",
        "dotenv": "17.4.2",
        "express": "5.2.1",
        "pino": "10.3.1",
        "pino-http": "11.0.0"
    },
    "devDependencies": {
        "@types/express": "5.0.6"
    }
}
